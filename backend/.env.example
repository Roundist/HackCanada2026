# Required for real agent analysis (Supply Chain, Tariff, Geopolitical, etc.)
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Backboard.io for persistent memory (fallback if unset)
# BACKBOARD_API_KEY=

# Optional: NewsAPI for live trade news (Geopolitical agent still runs without it)
# NEWSAPI_KEY=
